DJANGO_SECRET_KEY=changeme-use-a-secure-random-string
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
DATABASE_NAME=/app/data/db.sqlite3
STATIC_ROOT=/app/staticfiles

# E-mail / redefinicao de senha
# Se EMAIL_HOST ficar vazio, o app usa console backend para nao falhar.
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=True
EMAIL_USE_SSL=False
DEFAULT_FROM_EMAIL=Noivas & Cia <no-reply@tonicoimbra.com>
